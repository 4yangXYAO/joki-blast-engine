# Environment configuration example
# Do not commit real secrets. This file is for local development only.

# Logging level (see src/utils/logger.ts). Example: debug, info, warn, error
LOG_LEVEL=info

# API host and ports
API_HOST=localhost
API_PORT=3000
DASHBOARD_PORT=3001

# Database path
DATABASE_PATH=data/app.db

# JWT secret for signing tokens (DO NOT commit real secrets; replace in local env)
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ─── WhatsApp via Waha (self-hosted HTTP API) ────────────────────────────────
# Run Waha with: docker run -p 3001:3000 devlikeapro/waha
WAHA_BASE_URL=http://localhost:3001
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION=default

# Legacy WhatsApp Cloud API token (optional, used only if WAHA_BASE_URL is not set)
# WHATSAPP_CLOUD_API_TOKEN=

# ─── Telegram Bot API (existing Telegraf adapter) ────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token

# ─── Telegram MTProto / User Account (gramjs / Telethon-style) ───────────────
# Obtain apiId + apiHash from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash
# Session string: generate once with a one-time login script, store encrypted
TELEGRAM_SESSION=your-session-string

# ─── Social media cookies (IG, Twitter, Threads cookie-based adapters) ───────
# Cookie values are stored per-account in the dashboard (encrypted in DB).
# No env vars needed — set cookies via POST /v1/accounts with credentials field.

# ─── Instagram Graph API (existing adapter, optional) ─────────────────────────
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# INSTAGRAM_ALLOW_PRIVATE_API=false

# ─── Twitter/X API (existing adapter, optional) ───────────────────────────────
# TWITTER_BEARER_TOKEN=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# ─── Threads Graph API (existing adapter, optional) ───────────────────────────
# THREADS_ACCESS_TOKEN=
