{
  "name": "joki-blast-engine",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.20.0 <21"
  },
  "scripts": {
    "db:init": "ts-node ./scripts/db-init.ts",
    "db:validate": "node ./scripts/db-validate.ts",
    "validate:config": "node -r ts-node/register ./scripts/validate-config.js",
    "dev:api": "node -r dotenv/config -r ts-node/register/transpile-only -e \"require('./src/api/server').startServer()\"",
    "test": "vitest run"
  },
  "dependencies": {
    "async-mutex": "^0.3.2",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "helmet": "^8.0.0",
    "sql.js": "^1.14.1",
    "telegram": "^2.26.22",
    "winston": "^3.9.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.18",
    "@types/node": "^18.15.11",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^1.3.0"
  }
}
